# =============================================================================
# AI Agent Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control - it contains secrets!
# =============================================================================

# =============================================================================
# CORE SERVICE CONFIGURATION
# =============================================================================

# Environment: development | production | test
AGENT_ENVIRONMENT=development

# Server binding (internal to container)
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# =============================================================================
# SECURITY SECRETS (CRITICAL - Generate before deployment)
# =============================================================================

# PostgreSQL database credentials
# Generate password: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generate-with-openssl-rand-hex-16>
POSTGRES_DB=agent_db

# User credential encryption key
# Encrypts stored OAuth tokens and API keys in the database
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_CREDENTIAL_ENCRYPTION_KEY=<generate-fernet-key>

# Agent API authentication keys
# These protect agent endpoints, admin dashboard, and diagnostic APIs
# Generate each: openssl rand -hex 32
AGENT_INTERNAL_API_KEY=<generate-with-openssl-rand-hex-32>
AGENT_ADMIN_API_KEY=<generate-with-openssl-rand-hex-32>
AGENT_DIAGNOSTIC_API_KEY=<generate-with-openssl-rand-hex-32>

# Admin portal JWT session secret
AGENT_ADMIN_JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Qdrant API key (also set QDRANT__SERVICE__API_KEY to same value)
AGENT_QDRANT_API_KEY=<generate-with-openssl-rand-hex-32>
QDRANT__SERVICE__API_KEY=<same-as-above>

# SearxNG session secret
SEARXNG_SECRET=<generate-with-openssl-rand-hex-32>

# Open WebUI session secret
OPENWEBUI_SECRET=<generate-with-openssl-rand-hex-32>

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection URL (used by agent service)
POSTGRES_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/agent_db

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# LiteLLM connection
AGENT_LITELLM_API_BASE=http://litellm:4000
AGENT_LITELLM_MODEL=ollama/llama3.1:8b
AGENT_LITELLM_API_KEY=  # Optional: for external LiteLLM instances

# Qdrant vector database
AGENT_QDRANT_URL=http://qdrant:6333
AGENT_QDRANT_COLLECTION=agent-memories

# SearxNG search engine (used for web search)
SEARXNG_URL=http://searxng:8080

# Web fetcher service
AGENT_WEBFETCH_URL=http://webfetch:8081

# =============================================================================
# DOMAIN CONFIGURATION (Traefik + Let's Encrypt)
# =============================================================================

# Production domain (used when AGENT_ENVIRONMENT=production)
DOMAIN=agent.example.com

# Development domain (used when AGENT_ENVIRONMENT=development)
DOMAIN_DEV=agent-dev.example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# =============================================================================
# OAUTH / AUTHENTICATION
# =============================================================================

# Microsoft Entra ID (Azure AD) - Used by Open WebUI and Admin Portal
# Create App Registration at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Required redirect URIs:
#   - https://{DOMAIN}/oauth/microsoft/callback (production)
#   - https://{DOMAIN_DEV}/oauth/microsoft/callback (development)
MICROSOFT_CLIENT_ID=<your-azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<your-azure-app-client-secret>
MICROSOFT_CLIENT_TENANT_ID=<your-azure-tenant-id>

# OAuth redirect URIs for integrations (auto-set based on environment)
# These reference DOMAIN or DOMAIN_DEV based on AGENT_ENVIRONMENT
AGENT_OAUTH_REDIRECT_URI_PROD=https://${DOMAIN}/platformadmin/oauth/callback
AGENT_OAUTH_REDIRECT_URI_DEV=https://${DOMAIN_DEV}/platformadmin/oauth/callback

# Homey OAuth Integration (optional)
# Register at: https://tools.developer.homey.app/
AGENT_HOMEY_OAUTH_ENABLED=false
AGENT_HOMEY_AUTHORIZATION_URL=https://api.athom.com/oauth2/authorise
AGENT_HOMEY_TOKEN_URL=https://api.athom.com/oauth2/token
AGENT_HOMEY_CLIENT_ID=<your-homey-oauth-client-id>
AGENT_HOMEY_CLIENT_SECRET=<your-homey-oauth-client-secret>

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================

# Azure DevOps Integration
AZURE_DEVOPS_ORG=<your-organization>
AZURE_DEVOPS_PROJECT=<your-project>
AZURE_DEVOPS_PAT=<your-personal-access-token>
# AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org

# GitHub Personal Access Token (for creating PRs via claude_code tool)
# Generate at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxx

# Resend API for email notifications
# Get API key at: https://resend.com/
AGENT_RESEND_API_KEY=
AGENT_EMAIL_FROM_ADDRESS=no-reply@example.com

# OpenRouter API key (optional - for LiteLLM routing)
OPENROUTER_API_KEY=

# =============================================================================
# FEATURE CONFIGURATION
# =============================================================================

# RAG / Vector Search
ENABLE_QDRANT=true
ENABLE_RAG=true
QDRANT_TOP_K=5
MMR_LAMBDA=0.7
RAG_MAX_SOURCES=5
RAG_MAX_CHARS=1200

# CORS allowed origins (comma-separated, empty = disabled)
AGENT_CORS_ALLOWED_ORIGINS=

# Skills directory (mounted in container)
SKILLS_DIR=/app/skills

# Workspace base directory for git clones
AGENT_WORKSPACE_BASE=/tmp/agent-workspaces

# Locale / timezone
TIMEZONE=Europe/Stockholm

# =============================================================================
# CONTAINER IMAGES (SHA-pinned for supply chain security)
# =============================================================================

# To update: docker pull <image>:<tag> && docker inspect --format='{{index .RepoDigests 0}}' <image>:<tag>
LITELLM_IMAGE=ghcr.io/berriai/litellm@sha256:6eb7f8bdc47baf3aa07d3d7b2ddc330662ed28811a2a03ba32c8a548809f30e3
OLLAMA_IMAGE=ollama/ollama@sha256:e8c3d1f6ad16323bc40dc63eff0701d4fc32113f75a86b54b3e836eef8290de6
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui@sha256:53a4d2fc8c7a7cc620cd18e6fe416ed9940f2db87fddf837e3aa55111bec6995
SEARXNG_IMAGE=searxng/searxng@sha256:d477c0460cc06afa57541f24c7adcae3846303a125c3ae785b9893c9c2c2186f

# =============================================================================
# DOCKER / STACK CLI CONFIGURATION
# =============================================================================

# Docker BuildKit (1=enabled, 0=disabled)
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# STACK_PROJECT_NAME is intentionally NOT set here.
# The stack CLI derives project names automatically:
#   dev:  ai-agent-platform-dev  (DEV_PROJECT_NAME in stack/utils.py)
#   prod: ai-agent-platform-prod (PROD_PROJECT_NAME in stack/utils.py)
# Setting this variable overrides those computed names and can route
# data to the wrong Docker volume, causing silent data loss.

# =============================================================================
# OBSOLETE / REMOVED CONFIGURATION
# =============================================================================
# The following were previously used but are no longer needed:
#
# - COUCHDB_* variables: CouchDB removed